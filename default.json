{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "TasukuKuchinomachi 個人用 Renovate 共有プリセット",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":ignoreModulesAndTests",
    "group:monorepos",
    "group:recommended",
    "replacements:all",
    "workarounds:all"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": ["before 9am on monday"],
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "rangeStrategy": "bump",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dependency Dashboard",
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": ["security", "renovate"]
  },
  "configMigration": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "labels": ["renovate", "dependencies"],
  "branchPrefix": "renovate-nomach/",
  "commitMessagePrefix": "chore(deps):",
  "semanticCommits": "enabled",
  "platformAutomerge": false,
  "rebaseWhen": "conflicted",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "description": "GitHub Packages (個人 scope) は npm.pkg.github.com を参照",
      "matchPackageNames": ["/^@tasukukuchinomachi//"],
      "registryUrls": ["https://npm.pkg.github.com"]
    },
    {
      "description": "devDependencies の patch/minor はまとめる",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "devDependencies (non-major)"
    },
    {
      "description": "型定義",
      "matchPackageNames": ["/^@types//"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "type definitions"
    },
    {
      "description": "ESLint 系",
      "matchPackageNames": ["eslint", "/^eslint-/", "/^@typescript-eslint//"],
      "groupName": "eslint"
    },
    {
      "description": "テストランナー",
      "matchPackageNames": ["vitest", "/^@vitest//", "jest", "/^@jest//", "ts-jest"],
      "groupName": "test runners"
    },
    {
      "description": "GitHub Actions はまとめて SHA pin",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "pinDigests": true
    },
    {
      "description": "major は個別 PR、レビュー必須ラベル",
      "matchUpdateTypes": ["major"],
      "addLabels": ["major-update", "needs-review"],
      "prPriority": -1
    }
  ]
}
